# App
PORT=3000
NODE_ENV=development

# Dev Inspector
REACT_EDITOR=code

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/base-template
DIRECT_URL=postgresql://user:password@localhost:5432/base-template

# Redis
REDIS_URL=redis://localhost:6379

# Audit Log Rotation (days, default: 90)
AUDIT_LOG_RETENTION_DAYS=90

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Role
SUPER_ADMIN_EMAIL=admin@example.com

# Telegram Notification (optional)
TELEGRAM_NOTIFY_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# MCP server secrets (POST /mcp)
# MCP_SECRET grants readonly tools; MCP_SECRET_ADMIN grants writes + dev automation.
# Leave both empty to disable the HTTP endpoint.
MCP_SECRET=
MCP_SECRET_ADMIN=
